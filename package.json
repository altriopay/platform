{
  "name": "platform",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.5.5",
      "next-themes": "^0.4.6",
      "@orpc/client": "^1.13.14",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @platform/db db:push",
    "db:studio": "turbo -F @platform/db db:studio",
    "db:generate": "turbo -F @platform/db db:generate",
    "db:migrate": "turbo -F @platform/db db:migrate",
    "db:start": "turbo -F @platform/db db:start",
    "db:watch": "turbo -F @platform/db db:watch",
    "db:stop": "turbo -F @platform/db db:stop",
    "db:down": "turbo -F @platform/db db:down",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@platform/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@platform/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.1"
}
